{
  "info": {
    "name": "Warehouse Auction API",
    "description": "Postman collection for Warehouse Auction House API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": "{{base_url}}/api/v1/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"Password123\"}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": "{{base_url}}/api/v1/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"Password123\"}"
            }
          }
        },
        {
          "name": "Verify Email",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/auth/verify-email?token={{verification_token}}"
          }
        },
        {
          "name": "Resend Verification",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": "{{base_url}}/api/v1/auth/resend-verification",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\"}"
            }
          }
        },
        {
          "name": "Request Password Reset",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": "{{base_url}}/api/v1/auth/request-password-reset",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\"}"
            }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": "{{base_url}}/api/v1/auth/reset-password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{reset_token}}\",\n  \"password\": \"NewPassword123\"}"
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
            "url": "{{base_url}}/api/v1/users"
          }
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
            "url": "{{base_url}}/api/v1/users/{{user_id}}"
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Authorization", "value": "Bearer {{jwt_token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "url": "{{base_url}}/api/v1/users/{{user_id}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"updated@example.com\",\n  \"status\": \"ACTIVE\",\n  \"role\": {\n    \"id\": 2\n  }\n}"
            }
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
            "url": "{{base_url}}/api/v1/users/{{user_id}}"
          }
        }
      ]
    },
    {
      "name": "User Profile",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
            "url": "{{base_url}}/api/v1/users/{{user_id}}/profile"
          }
        },
        {
          "name": "Create/Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Authorization", "value": "Bearer {{jwt_token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "url": "{{base_url}}/api/v1/users/{{user_id}}/profile",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"John Doe\",\n  \"mobileNumber\": \"+1234567890\",\n  \"country\": \"USA\",\n  \"city\": \"New York\",\n  \"street\": \"123 Main St\",\n  \"building\": \"Apt 4B\",\n  \"postalCode\": \"10001\"\n}"
            }
          }
        },
        {
          "name": "Upload Profile Picture",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
            "url": "{{base_url}}/api/v1/users/{{user_id}}/profile/picture",
            "body": {
              "mode": "formdata",
              "formdata": [
                {"key": "file", "type": "file", "src": "/path/to/photo.jpg"}
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Roles",
      "item": [
        {
          "name": "Get All Roles",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
            "url": "{{base_url}}/api/v1/roles"
          }
        },
        {
          "name": "Get Role by ID",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
            "url": "{{base_url}}/api/v1/roles/{{role_id}}"
          }
        },
        {
          "name": "Create Role",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{jwt_token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "url": "{{base_url}}/api/v1/roles",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"MANAGER\",\n  \"description\": \"Manager role\"\n}"
            }
          }
        },
        {
          "name": "Update Role",
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Authorization", "value": "Bearer {{jwt_token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "url": "{{base_url}}/api/v1/roles/{{role_id}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"UPDATED_ROLE\",\n  \"permissions\": [\n    {\"id\": 1},\n    {\"id\": 2}\n  ]\n}"
            }
          }
        },
        {
          "name": "Delete Role",
          "request": {
            "method": "DELETE",
            "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
            "url": "{{base_url}}/api/v1/roles/{{role_id}}"
          }
        },
        {
          "name": "Add Permissions to Role",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{jwt_token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "url": "{{base_url}}/api/v1/roles/{{role_id}}/permissions",
            "body": {
              "mode": "raw",
              "raw": "[1, 2, 3]"
            }
          }
        },
        {
          "name": "Remove Permission from Role",
          "request": {
            "method": "DELETE",
            "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
            "url": "{{base_url}}/api/v1/roles/{{role_id}}/permissions/{{permission_id}}"
          }
        }
      ]
    },
    {
      "name": "Permissions",
      "item": [
        {
          "name": "Get All Permissions",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
            "url": "{{base_url}}/api/v1/permissions"
          }
        },
        {
          "name": "Get Permission by ID",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
            "url": "{{base_url}}/api/v1/permissions/{{permission_id}}"
          }
        },
        {
          "name": "Create Permission",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{jwt_token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "url": "{{base_url}}/api/v1/permissions",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"user:create\"\n}"
            }
          }
        },
        {
          "name": "Update Permission",
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Authorization", "value": "Bearer {{jwt_token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "url": "{{base_url}}/api/v1/permissions/{{permission_id}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"user:update\"\n}"
            }
          }
        },
        {
          "name": "Delete Permission",
          "request": {
            "method": "DELETE",
            "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
            "url": "{{base_url}}/api/v1/permissions/{{permission_id}}"
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "Get All Categories",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
            "url": "{{base_url}}/api/v1/categories"
          }
        },
        {
          "name": "Get Category by ID",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
            "url": "{{base_url}}/api/v1/categories/{{category_id}}"
          }
        },
        {
          "name": "Create Category",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{jwt_token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "url": "{{base_url}}/api/v1/categories",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Electronics\",\n  \"description\": \"Electronic items and gadgets\"\n}"
            }
          }
        },
        {
          "name": "Update Category",
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Authorization", "value": "Bearer {{jwt_token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "url": "{{base_url}}/api/v1/categories/{{category_id}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Electronics\",\n  \"description\": \"Updated description\"\n}"
            }
          }
        },
        {
          "name": "Delete Category",
          "request": {
            "method": "DELETE",
            "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
            "url": "{{base_url}}/api/v1/categories/{{category_id}}"
          }
        }
      ]
    },
    {
      "name": "Auction Items",
      "item": [
        {
          "name": "Get All Auction Items",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
            "url": "{{base_url}}/api/v1/auction-items"
          }
        },
        {
          "name": "Get Auction Item by ID",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
            "url": "{{base_url}}/api/v1/auction-items/{{item_id}}"
          }
        },
        {
          "name": "Create Auction Item",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{jwt_token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "url": "{{base_url}}/api/v1/auction-items",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Vintage Watch\",\n  \"description\": \"A beautiful vintage timepiece\",\n  \"category\": {\n    \"id\": 1\n  }\n}"
            }
          }
        },
        {
          "name": "Update Auction Item",
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Authorization", "value": "Bearer {{jwt_token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "url": "{{base_url}}/api/v1/auction-items/{{item_id}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Watch\",\n  \"description\": \"Updated description\",\n  \"status\": \"AUCTION\"\n}"
            }
          }
        },
        {
          "name": "Upload Display Image",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
            "url": "{{base_url}}/api/v1/auction-items/{{item_id}}/display-image",
            "body": {
              "mode": "formdata",
              "formdata": [
                {"key": "file", "type": "file", "src": "/path/to/item.jpg"}
              ]
            }
          }
        },
        {
          "name": "Upload Gallery Images",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
            "url": "{{base_url}}/api/v1/auction-items/{{item_id}}/gallery-images",
            "body": {
              "mode": "formdata",
              "formdata": [
                {"key": "files", "type": "file", "src": "/path/to/image1.jpg"},
                {"key": "files", "type": "file", "src": "/path/to/image2.jpg"}
              ]
            }
          }
        },
        {
          "name": "Delete Auction Item",
          "request": {
            "method": "DELETE",
            "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
            "url": "{{base_url}}/api/v1/auction-items/{{item_id}}"
          }
        }
      ]
    },
    {
      "name": "Auctions",
      "item": [
        {
          "name": "Get All Auctions",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
            "url": "{{base_url}}/api/v1/auctions"
          }
        },
        {
          "name": "Get Auction by ID",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
            "url": "{{base_url}}/api/v1/auctions/{{auction_id}}"
          }
        },
        {
          "name": "Create Auction",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{jwt_token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "url": "{{base_url}}/api/v1/auctions",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"startPrice\": 100.0,\n  \"startsAt\": \"2026-12-01T10:00:00\",\n  \"endsAt\": \"2026-12-10T10:00:00\",\n  \"minimumIncrement\": 10.0,\n  \"auctionItem\": {\n    \"id\": 1\n  }\n}"
            }
          }
        },
        {
          "name": "Update Auction",
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Authorization", "value": "Bearer {{jwt_token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "url": "{{base_url}}/api/v1/auctions/{{auction_id}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"CANCELLED\",\n  \"endsAt\": \"2026-12-15T10:00:00\"\n}"
            }
          }
        },
        {
          "name": "Delete Auction",
          "request": {
            "method": "DELETE",
            "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
            "url": "{{base_url}}/api/v1/auctions/{{auction_id}}"
          }
        }
      ]
    },
    {
      "name": "Bids",
      "item": [
        {
          "name": "Place Bid",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{jwt_token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "url": "{{base_url}}/api/v1/auctions/{{auction_id}}/bids",
            "body": {
              "mode": "raw",
              "raw": "120.0"
            }
          }
        },
        {
          "name": "Get All Bids for Auction",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
            "url": "{{base_url}}/api/v1/auctions/{{auction_id}}/bids"
          }
        },
        {
          "name": "Get Highest Bid",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
            "url": "{{base_url}}/api/v1/auctions/{{auction_id}}/bids/highest"
          }
        },
        {
          "name": "Get Bid Count",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
            "url": "{{base_url}}/api/v1/auctions/{{auction_id}}/bids/count"
          }
        }
      ]
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [""]
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "jwt_token",
      "value": "your_jwt_token_here",
      "type": "string"
    },
    {
      "key": "user_id",
      "value": "1",
      "type": "string"
    },
    {
      "key": "role_id",
      "value": "1",
      "type": "string"
    },
    {
      "key": "permission_id",
      "value": "1",
      "type": "string"
    },
    {
      "key": "category_id",
      "value": "1",
      "type": "string"
    },
    {
      "key": "item_id",
      "value": "1",
      "type": "string"
    },
    {
      "key": "auction_id",
      "value": "1",
      "type": "string"
    },
    {
      "key": "verification_token",
      "value": "your_verification_token",
      "type": "string"
    },
    {
      "key": "reset_token",
